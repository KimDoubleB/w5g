# 로컬 개발용: 이 파일을 .env.local 로 복사한 뒤 실제 값을 채워 넣으세요.
# .env.local 은 git 에 커밋되지 않습니다 (.gitignore 처리).
# GitHub Pages 배포 시에는 같은 키를 GitHub Repository Secrets 에 등록하면
# Actions 워크플로우가 빌드 시점에 자동으로 주입합니다.

# ---------- 연락처 (선택) ----------
VITE_PHONE_GROOM=
VITE_PHONE_GROOM_FATHER=
VITE_PHONE_GROOM_MOTHER=
VITE_PHONE_BRIDE=
VITE_PHONE_BRIDE_FATHER=
VITE_PHONE_BRIDE_MOTHER=

# ---------- 계좌번호 (선택) ----------
VITE_ACCT_GROOM_BANK=
VITE_ACCT_GROOM_NUMBER=
VITE_ACCT_GROOM_FATHER_BANK=
VITE_ACCT_GROOM_FATHER_NUMBER=
VITE_ACCT_GROOM_MOTHER_BANK=
VITE_ACCT_GROOM_MOTHER_NUMBER=

VITE_ACCT_BRIDE_BANK=
VITE_ACCT_BRIDE_NUMBER=
VITE_ACCT_BRIDE_FATHER_BANK=
VITE_ACCT_BRIDE_FATHER_NUMBER=
VITE_ACCT_BRIDE_MOTHER_BANK=
VITE_ACCT_BRIDE_MOTHER_NUMBER=

# ---------- 지도 외부 링크 (개인정보 아님, 편의상 같이) ----------
# VITE_MAP_NAVER : 네이버지도 공유 링크 (https://map.naver.com/p/...)
# VITE_MAP_KAKAO : 카카오맵 장소 링크 (https://map.kakao.com/?...)
# VITE_MAP_TMAP  : 티맵 장소 링크 (https://surl.tmobiapi.com/... 또는 tmap://route?goalname=)
VITE_MAP_NAVER=
VITE_MAP_KAKAO=
VITE_MAP_TMAP=
