# --- Dependencies ---
node_modules/
.pnp/
.pnp.js
.pnp.cjs
.yarn/cache
.yarn/install-state.gz

# --- Build output ---
dist/
dist-ssr/
*.tsbuildinfo

# --- Vite / Vitest cache ---
.vite/
.vitest/
coverage/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Local secrets (phone numbers, account numbers) ---
# Real values live in GitHub Actions Secrets at build time;
# locally use .env.local. Never commit any .env* file with real data.
.env
.env.local
.env.*.local

# --- OS metadata ---
.DS_Store
Thumbs.db
# WSL: when copying from Windows, the filesystem mirrors the NTFS Alternate
# Data Stream as a sibling file ending with ':Zone.Identifier'. Ignore.
*Zone.Identifier

# --- Editor / IDE ---
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Playwright (MCP) artifacts ---
/.playwright-mcp/
/playwright-report/
/test-results/

# --- Image originals (resize-images.mjs backups) ---
/public/img/_original/

# --- Misc ---
*.local
